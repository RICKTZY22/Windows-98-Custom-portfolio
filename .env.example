# Media library - host the actual files OUTSIDE this repo (Cloudinary, Vercel Blob,
# unlisted host, etc.) and put only the public URLs here.
#
# Copy this file to `.env.local` for local development (`.env.local` is git-ignored,
# so your real URLs never get committed). For the live site, add the same variables
# in the Vercel dashboard: Settings -> Environment Variables.
#
# Each value is a JSON array of { "name", "src" } objects. `name` MUST include a real
# file extension so the Gallery recognizes the type:
#   images -> .png .jpg .jpeg .gif .webp .avif .svg
#   videos -> .mp4 .webm .mov .mkv .avi .ogg
#   music  -> .wav .mp3 .mid .ogg
#
# Note: these URLs are baked into the deployed site, so a visitor on the live site can
# still reach them - that is expected. They are NOT in the repo, so repo visitors cannot.

VITE_GALLERY_PHOTOS=[{"name":"example-photo.jpg","src":"https://your-host.example/example-photo.jpg"}]
VITE_GALLERY_VIDEOS=[{"name":"how-it-was-made.mp4","src":"https://your-host.example/how-it-was-made.mp4"}]
VITE_GALLERY_MUSIC=[{"name":"theme.mp3","src":"https://your-host.example/theme.mp3"}]
